  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ChallengeTipsPresenter
  challengeRoomController: {fileID: 0}
  tipsPanelUI: {fileID: 0}
  tipsSeenTracker: {fileID: 0}
  autoShowOnInitialize: 1
  log: 0
  generalChallengePages:
  - title: CHALLENGE ROOMS
    body: 'Challenge rooms are risky bargains.


      Instead of normal combat,
      they offer a special trial. If you succeed, you gain a temporary effect. If
      you fail, you may suffer a temporary penalty.'
  - title: TEMPORARY EFFECTS
    body: 'Challenge effects stay with you until you enter another Challenge room.


      That
      means each new challenge can replace your old bargain with a new one.'
  specificTipSets:
  - challengeType: 1
    title: BETTING
    body: 'In Betting, you wager AP on hellhound racers.


      Choose carefully.
      A good bet can strengthen your run. A bad bet can cripple your action economy.'
  - challengeType: 2
    title: GLUTTONY
    body: 'In Gluttony, greed is the trap.


      You will be tempted to push for
      more than is safe. Too much hunger can turn reward into punishment.'
  - challengeType: 3
    title: SLOTH
    body: 'In Sloth, timing matters more than aggression.


      Do not rush. Wait,
      read, and act at the right moment.'
  - challengeType: 4
    title: LIE
    body: 'Lie is the cruelest challenge.


      Its rules may shift, deceive, or
      chain multiple punishments and rewards together. Trust nothing blindly.'
